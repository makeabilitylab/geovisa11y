# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# API Keys
REACT_APP_MAPBOX_TOKEN=pk.your_mapbox_token_here
OPENAI_API_KEY=sk-your_openai_key_here

# Environment Settings
NODE_ENV=development
FLASK_ENV=development

# API URLs
REACT_APP_API_URL=http://localhost:5000

# Database & Infrastructure
DATABASE_PATH=backend/database/spatial-db.db
MONGO_URI=mongodb+srv://username:password@your-cluster.mongodb.net/?retryWrites=true&w=majority&appName=YourApp

# CORS Settings
CORS_ORIGINS=http://localhost:3000,https://your-app.web.app
